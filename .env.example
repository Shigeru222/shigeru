ANTHROPIC_API_KEY=your_api_key_here

# Optional: Claude model to use for all eiken API routes.
# Default (when unset) is claude-sonnet-4-6 — fast and well within Vercel Hobby's
# 60s function timeout. Override examples:
#   CLAUDE_MODEL=claude-opus-4-7        # higher quality, slower (may timeout)
#   CLAUDE_MODEL=claude-haiku-4-5-20251001  # fastest, lowest cost
# CLAUDE_MODEL=
